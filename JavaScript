// Filtro de projetos
function filtrar(tipo) {
  const cards = document.querySelectorAll('.card');

  cards.forEach(card => {
    if (tipo === 'todos' || card.classList.contains(tipo)) {
      card.style.display = 'block';
    } else {
      card.style.display = 'none';
    }
  });
}

