* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial;
}

header {
  background: #333;
  color: white;
  padding: 10px;
}

nav ul {
  display: flex;
  list-style: none;
  gap: 10px;
}

section {
  padding: 20px;
}

.card {
  background: #eee;
  margin: 10px;
  padding: 10px;
  border-radius: 8px;
}

/* Responsivo */
@media (max-width: 600px) {
  nav ul {
    flex-direction: column;
  }
}
