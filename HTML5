<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Meu Portfólio</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <nav>
    <h1>Meu Site</h1>
    <ul>
      <li><a href="#home">Home</a></li>
      <li><a href="#sobre">Sobre</a></li>
      <li><a href="#projetos">Projetos</a></li>
      <li><a href="#contato">Contato</a></li>
    </ul>
  </nav>
</header>

<main>
  <section id="home">
    <h2>Bem-vindo</h2>
    <p>Este é meu portfólio.</p>
  </section>

  <section id="sobre">
    <h2>Sobre Mim</h2>
    <p>Sou estudante de tecnologia.</p>
  </section>

  <section id="projetos">
    <h2>Projetos</h2>
    <button onclick="filtrar('todos')">Todos</button>
    <button onclick="filtrar('web')">Web</button>
    
    <div class="card web">Projeto 1</div>
    <div class="card">Projeto 2</div>
  </section>

  <section id="contato">
    <h2>Contato</h2>
    <form id="form">
      <input type="text" placeholder="Nome" required>
      <input type="email" placeholder="Email" required>
      <button type="submit">Enviar</button>
    </form>
  </section>
</main>

<footer>
  <p>© 2026 Meu Site</p>
</footer>

<script src="script.js"></script>
</body>
</html>
